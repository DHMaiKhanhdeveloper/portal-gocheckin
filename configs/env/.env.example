# =====================================================
# Sample env file — copy to .env.local / .env.stage / .env.prod
# DO NOT commit real credentials. Real env files are in .gitignore.
# =====================================================

# Runtime
ENV=local
HEADLESS=true
SLOW_MO=0
# Override the browser timezone if the merchant is not US/Pacific.
# TZ_ID=America/Los_Angeles

# GoCheckin POS portal
BASE_URL=https://pos.gocheckin.net
API_BASE_URL=https://api.gocheckin.net
API_TIMEOUT=30000

# Role-based seed accounts (used by tests/auth.setup.ts)
CASHIER_USER=
CASHIER_PASS=
ADMIN_USER=
ADMIN_PASS=

# Logging
LOG_LEVEL=info
