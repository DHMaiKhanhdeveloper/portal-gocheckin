# Force LF in the repo for all text files so Windows/macOS/Linux check out the
# same content. core.autocrlf may still show CRLF locally on Windows.
* text=auto eol=lf

package-lock.json text eol=lf
*.json            text eol=lf
*.yml             text eol=lf
*.yaml            text eol=lf
*.md              text eol=lf
*.ts              text eol=lf
*.tsx             text eol=lf
*.js              text eol=lf
*.mjs             text eol=lf
*.cjs             text eol=lf

*.sh              text eol=lf
*.bat             text eol=crlf
*.cmd             text eol=crlf
*.ps1             text eol=crlf

*.png             binary
*.jpg             binary
*.jpeg            binary
*.gif             binary
*.ico             binary
*.pdf             binary
*.zip             binary
